{
  "name": "clusterfuck",
  "private": true,
  "version": "0.5.4",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./packages/*\" dev",
    "dev:web": "pnpm --filter @clusterfuck/web dev",
    "dev:proxy": "pnpm --filter @clusterfuck/proxy dev",
    "build": "pnpm --recursive --if-present build",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "lint": "oxlint",
    "test": "pnpm --recursive --if-present test"
  },
  "devDependencies": {
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2"
  }
}
