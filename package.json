{
  "name": "clusterfuck",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,proxy -c blue,green \"npm run dev --workspace=@clusterfuck/web\" \"npm run dev --workspace=@clusterfuck/proxy\"",
    "dev:web": "npm run dev --workspace=@clusterfuck/web",
    "dev:proxy": "npm run dev --workspace=@clusterfuck/proxy",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "oxlint",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2"
  }
}
